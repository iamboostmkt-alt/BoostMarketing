# Copy to .env and fill in real values. NEVER commit .env.

# ── Database ─────────────────────────────────────────────────────────────────
# Supabase connection-pooler URL (runtime / queries)
DATABASE_URL="postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-X-REGION.pooler.supabase.com:6543/postgres?sslmode=require"

# Supabase direct URL (Prisma migrations & seeds — bypasses pgBouncer)
DIRECT_URL="postgresql://postgres:DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES"

# ── Google OAuth (optional — leave blank to disable) ─────────────────────────
# Register redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email / Nodemailer (optional) ────────────────────────────────────────────
# In development, magic links & reset URLs are printed to the server console.
# Production example: smtps://user:password@smtp.gmail.com:465
EMAIL_SERVER=""
EMAIL_FROM="BoostMarketing <noreply@boostmkt.com>"
