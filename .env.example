# Copy this file to .env and fill in real values. NEVER commit .env.

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Pooler URL — used at runtime (port 6543, pgBouncer)
DATABASE_URL="postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-X-REGION.pooler.supabase.com:6543/postgres?sslmode=require"

# Direct URL — used by Prisma for db push / migrations (port 5432, bypasses pgBouncer)
DIRECT_URL="postgresql://postgres:DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Local: http://localhost:3000  |  Production: https://boostmarketingboost.com
NEXTAUTH_URL="http://localhost:3000"
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES"

# ── Google OAuth (optional — leave blank to disable) ─────────────────────────
# Register redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Supabase Storage + Realtime ──────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."          # service_role key — server only
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."      # anon/public key — enables Realtime on the client

# ── Email ─────────────────────────────────────────────────────────────────────
# Gmail SMTP (test-email + puede usarse con otros flujos que importen @/lib/mailer)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
# Opcional: "true" para puerto 465 SSL
EMAIL_SERVER_SECURE=""
EMAIL_SERVER_USER="tu_cuenta@gmail.com"
EMAIL_SERVER_PASSWORD="xxxx xxxx xxxx xxxx"
EMAIL_FROM="BoostMarketing <tu_cuenta@gmail.com>"

# Magic link / reset vía Nodemailer URL (NextAuth sendVerificationRequest en auth.ts)
# Ejemplo: smtps://user:pass@smtp.gmail.com:465
EMAIL_SERVER=""

# Resend (si el proyecto lo usa en otro módulo)
RESEND_API_KEY=""
