# Copy to .env and fill values. Never commit .env.

DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="YOUR_NEXTAUTH_SECRET_REPLACE_WITH_RANDOM_32_PLUS_BYTES"

# Google OAuth — redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# Magic link (production) — Nodemailer transport URL, e.g. smtps://user:pass@smtp.example.com:465
# In development, links are printed to the server console instead.
EMAIL_SERVER=""
EMAIL_FROM="BoostMarketing <noreply@your-domain.com>"
