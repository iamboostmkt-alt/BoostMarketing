generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  UNASSIGNED
  CLIENT
  ADMIN
  PROJECT_MANAGER
  TEAM_MEMBER
  DESIGNER
  MARKETING
  SALES_REP
}

/// Ciclo de vida SaaS del usuario (típico en role CLIENT; null en otros)
enum UserLifecycleStatus {
  PROSPECT
  INVITED
  ACTIVE
  INACTIVE
}


model Workspace {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  plan             String    @default("FREE") // FREE | PRO | BUSINESS | ENTERPRISE
  trialEndsAt      DateTime? @map("trial_ends_at")
  isFoundingMember Boolean   @default(false) @map("is_founding_member")
  stripeCustomerId String?   @map("stripe_customer_id")
  stripeSubId      String?   @map("stripe_sub_id")
  billingCycle     String    @default("monthly") @map("billing_cycle") // monthly | annual
  extraClients     Int       @default(0) @map("extra_clients")
  aiTier           String    @default("basic") @map("ai_tier") // basic | medium | premium
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  users         User[]
  clients       Client[]
  tasks         Task[]
  appointments  Appointment[]
  activities    Activity[]
  milestones    Milestone[]
  notifications Notification[]
  activityLogs  ActivityLog[]
  contacts      Contact[]
  chatMessages  ChatMessage[]
  chatUnreads   ChatUnread[]
  channels      Channel[]
  aiSessions    AiSession[]
  pushSubscriptions PushSubscription[]
  projects      Project[]
  invites       WorkspaceInvite[]
  taskTemplates      TaskTemplate[]
  customRoles        CustomRole[]
  analyticsSnapshots AnalyticsSnapshot[]

  @@map("workspaces")
}

model Account {
  id                String @id @default(cuid())
  userId            String @map("user_id")
  type              String
  provider          String
  providerAccountId String @map("provider_account_id")

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id              String               @id @default(cuid())
  name            String?
  email           String               @unique
  emailVerified   DateTime?            @map("email_verified")
  password        String?
  image           String?
  role            Role                 @default(UNASSIGNED)
  /// PROSPECT: lead desde videollamada; ACTIVE/INACTIVE: gestión admin
  lifecycleStatus UserLifecycleStatus? @map("lifecycle_status")
  color           String               @default("#7c3aed")
  active          Boolean              @default(true)
  customRoleId    String?              @map("custom_role_id")
  workspaceId     String               @map("workspace_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts               Account[]
  sessions               Session[]
  notifications          Notification[]
  activityLogs           ActivityLog[]
  tasks                  Task[]                    @relation("OwnedTasks")
  assignedTasks          Task[]                    @relation("AssignedTasks")
  taskTemplates          TaskTemplate[]
  taskFeedback           TaskFeedback[]
  sentInvites            WorkspaceInvite[]         @relation("InvitedBy")
  contacts               Contact[]
  clients                Client[]
  assignedActivities     Activity[]                @relation("AssignedActivities")
  createdActivities      Activity[]                @relation("CreatedActivities")
  activityAssignments    ActivityAssignedUser[]
  taskAssignments        TaskAssignedUser[]
  taskAttachments        TaskAttachment[]
  responsibleMilestones  Milestone[]             @relation("MilestoneResponsible")
  clientAssignments      ClientAssignedUser[]
  customRole             CustomRole?               @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  chatMessages           ChatMessage[]
  chatReactions          ChatReaction[]
  chatUnreads           ChatUnread[]
  createdChannels       Channel[]             @relation("ChannelCreator")
  aiSessions            AiSession[]
  pushSubscriptions      PushSubscription[]
  managedClients         Client[]                  @relation("ClientManager")
  createdProjects        Project[]                 @relation("ProjectCreator")
  channelMemberships     ChannelMember[]
  projectAssignments     ProjectAssignedUser[]     @relation("ProjectUsers")
  activityComments       ActivityComment[]
  appointmentAssignments AppointmentAssignedUser[]
  presence               UserPresence?
  workspace              Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Notification {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  message     String
  type        String    @default("info")
  read        Boolean   @default(false)
  link        String?
  workspaceId String    @map("workspace_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  // Actor: quien generó la acción (null = sistema/cron)
  actorId     String?   @map("actor_id")
  actorName   String?   @map("actor_name")
  actorImage  String?   @map("actor_image")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([workspaceId, userId])
  @@map("notifications")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String
  entity    String
  entityId  String   @map("entity_id")
  details     String   @default("{}")
  workspaceId String   @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("activity_logs")
}

model Task {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  assignedUserId String?   @map("assigned_user_id")
  clientId       String?   @map("client_id")
  title          String
  description    String    @default("")
  status         String    @default("pending")
  priority       String    @default("medium")
  visibility     String    @default("internal")
  references     Json?     @default("[]") @map("task_references")
  startDate      DateTime? @map("start_date")
  dueDate        DateTime? @map("due_date")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  workspaceId  String    @map("workspace_id")
  parentTaskId String?   @map("parent_task_id")
  projectId    String?   @map("project_id")
  templateId   String?   @map("template_id")

  user          User               @relation("OwnedTasks", fields: [userId], references: [id], onDelete: Cascade)
  assignedUser  User?              @relation("AssignedTasks", fields: [assignedUserId], references: [id], onDelete: SetNull)
  client        Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assignedUsers TaskAssignedUser[]
  attachments   TaskAttachment[]
  subtasks      Task[]            @relation("TaskSubtasks")
  project       Project?          @relation("ProjectTasks", fields: [projectId], references: [id], onDelete: SetNull)
  parentTask    Task?             @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  template      TaskTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  feedback      TaskFeedback[]
  deliverableLogs DeliverableLog[]
  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  isDeliverable     Boolean  @default(false) @map("is_deliverable")
  deliverableStatus String?  @map("deliverable_status")
  milestoneId       String?  @map("milestone_id")
  archivedAt        DateTime? @map("archived_at")
  phase             String?  @default("general") // general | inicio | intermedio | avance | final
  type              String   @default("internal_task") // internal_task | deliverable | activity | review | change_request
  publishedAt       DateTime? @map("published_at")
  milestone         Milestone? @relation("MilestoneTasks", fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([assignedUserId, status])
  @@index([clientId, status])
  @@index([clientId, workspaceId])
  @@index([userId, status])
  @@index([dueDate, status])
  @@index([parentTaskId])
  // Recordatorios
  reminder3dSent    Boolean   @default(false) @map("reminder_3d_sent")
  reminder2d1Sent   Boolean   @default(false) @map("reminder_2d_1_sent")
  reminder2d2Sent   Boolean   @default(false) @map("reminder_2d_2_sent")
  reminder2d3Sent   Boolean   @default(false) @map("reminder_2d_3_sent")
  reminder1d1Sent   Boolean   @default(false) @map("reminder_1d_1_sent")
  reminder1d2Sent   Boolean   @default(false) @map("reminder_1d_2_sent")
  reminder1d3Sent   Boolean   @default(false) @map("reminder_1d_3_sent")
  reminder1d4Sent   Boolean   @default(false) @map("reminder_1d_4_sent")
  reminderD1Sent    Boolean   @default(false) @map("reminder_d1_sent")
  reminderD2Sent    Boolean   @default(false) @map("reminder_d2_sent")
  reminderD3Sent    Boolean   @default(false) @map("reminder_d3_sent")
  reminderD4Sent    Boolean   @default(false) @map("reminder_d4_sent")
  overdueCount      Int       @default(0) @map("overdue_count")
  overdueEscalated  Boolean   @default(false) @map("overdue_escalated")
  lastReminderAt    DateTime? @map("last_reminder_at")

  @@index([workspaceId, assignedUserId])
  @@map("tasks")
}

model Contact {
  id      String @id @default(cuid())
  userId  String @map("user_id")
  name    String
  email   String
  company String @default("")
  phone   String @default("")
  status  String @default("lead")
  value   Float  @default(0)
  notes   String @default("")
  source      String   @default("manual") // landing_video | landing_register | manual
  workspaceId String   @map("workspace_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([workspaceId, userId])
  @@map("contacts")
}

model Client {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  assignedManagerId String? @map("assigned_manager_id")
  name              String
  email             String
  company           String  @default("")
  phone             String  @default("")
  status            String  @default("active")
  links             Json    @default("[]")   @map("links")  // [{label,url,icon}]
  workspaceId       String  @map("workspace_id")
  // Portal de cliente
  portalId          String  @unique @default(cuid()) @map("portal_id")
  portalStatus      String  @default("pending") @map("portal_status") // pending | invited | active
  invitedAt         DateTime? @map("invited_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedManager User?                @relation("ClientManager", fields: [assignedManagerId], references: [id], onDelete: SetNull)
  activities      Activity[]
  tasks           Task[]
  assignedUsers   ClientAssignedUser[]
  milestones      Milestone[]
  appointments    Appointment[]
  projects        Project[]      @relation("ClientProjects")

  @@index([workspaceId, status])
  @@index([assignedManagerId, workspaceId])
  @@map("clients")
}

model Activity {
  id          String    @id @default(cuid())
  title       String
  description String    @default("")
  status      String    @default("pending")
  priority    String    @default("medium")
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")

  assignedUserId  String? @map("assigned_user_id")
  createdByUserId String  @map("created_by_user_id")
  clientId        String? @map("client_id")
  visibleToClient Boolean @default(false) @map("visible_to_client")
  workspaceId     String  @map("workspace_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace     Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedUser  User?                  @relation("AssignedActivities", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdBy     User                   @relation("CreatedActivities", fields: [createdByUserId], references: [id], onDelete: Cascade)
  client        Client?                @relation(fields: [clientId], references: [id], onDelete: SetNull)
  comments      ActivityComment[]
  assignedUsers ActivityAssignedUser[]

  @@map("activities")
}

model ActivityAssignedUser {
  id         String   @id @default(cuid())
  activityId String   @map("activity_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@map("activity_assigned_users")
}

model CustomRole {
  id          String @id @default(cuid())
  name        String @unique
  label       String
  color       String @default("#7c3aed")
  description String @default("")
  permissions Json   @default("{}")

  workspaceId String   @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users     User[]
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("custom_roles")
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  message   String
  room        String   @default("TEAM") // "TEAM" | clientId for per-client rooms
  workspaceId String   @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parentId  String?  @map("parent_id")
  fileUrl   String?  @map("file_url")
  fileName  String?  @map("file_name")
  fileType  String?  @map("file_type")
  taskId    String?  @map("task_id")
  pinned      Boolean  @default(false)
  isSystem    Boolean  @default(false) @map("is_system")
  systemName  String?  @map("system_name")   // "Weeklink" | "Boosti" etc
  isInternal  Boolean  @default(false) @map("is_internal") // true = solo equipo, false = visible al cliente
  reactions   ChatReaction[]

  @@index([workspaceId, room, createdAt])
  @@map("chat_messages")
}

model ChatReaction {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("chat_reactions")
}

model ActivityComment {
  id         String   @id @default(cuid())
  activityId String   @map("activity_id")
  userId     String   @map("user_id")
  message    String
  createdAt  DateTime @default(now()) @map("created_at")

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_comments")
}

model UserPresence {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  status    String   @default("online") // online | away | offline
  lastSeen  DateTime @default(now()) @map("last_seen")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_presence")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

model Appointment {
  id     String   @id @default(cuid())
  name   String
  email  String
  phone  String   @default("")
  date   DateTime
  notes  String   @default("")
  status String   @default("pending")

  meetUrl          String?   @map("meet_url")
  meetingProvider  String    @default("google_meet") @map("meeting_provider")
  isInternal       Boolean   @default(false) @map("is_internal")
  timezone         String    @default("America/Mexico_City")
  reminderCount    Int       @default(0) @map("reminder_count")
  reminder24hSent  Boolean   @default(false) @map("reminder_24h_sent")
  reminder1hSent   Boolean   @default(false) @map("reminder_1h_sent")
  reminder15mSent  Boolean   @default(false) @map("reminder_15m_sent")
  lastReminderAt   DateTime? @map("last_reminder_at")
  nextReminderAt   DateTime? @map("next_reminder_at")
  meetingStartedAt DateTime? @map("meeting_started_at")
  meetingEndedAt   DateTime? @map("meeting_ended_at")

  clientId    String?  @map("client_id")
  workspaceId String   @map("workspace_id")
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedUsers AppointmentAssignedUser[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([workspaceId, date])
  @@index([workspaceId, status])
  @@map("appointments")
}

model SiteSettings {
  id           String @id @default(cuid())
  agencyName   String @default("BoostMarketing") @map("agency_name")
  logoUrl      String @default("") @map("logo_url")
  faviconUrl   String @default("") @map("favicon_url")
  heroTitle    String @default("Escala tu marca con contenido y automatización") @map("hero_title")
  heroSubtitle String @default("Impulsamos tu presencia digital con estrategia, creatividad y marketing digital. Creamos contenido, campañas y experiencias que hacen crecer tu marca.") @map("hero_subtitle")
  email        String @default("")
  phone        String @default("")
  instagram    String @default("")
  facebook     String @default("")
  tiktok       String @default("")
  linkedin     String @default("")
  whatsapp     String @default("")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model PortfolioItem {
  id          String  @id @default(cuid())
  title       String
  description String  @default("")
  imageUrl    String  @default("") @map("image_url")
  tags        String  @default("")
  projectUrl  String  @default("") @map("project_url")
  order       Int     @default(0)
  active      Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("portfolio_items")
}

model Testimonial {
  id       String  @id @default(cuid())
  name     String
  role     String  @default("")
  company  String  @default("")
  text     String
  imageUrl String  @default("") @map("image_url")
  rating   Int     @default(5)
  active   Boolean @default(true)
  order    Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("testimonials")
}

model TaskAssignedUser {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@map("task_assigned_users")
}

model ClientAssignedUser {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
  @@map("client_assigned_users")
}

model TeamMember {
  id       String  @id @default(cuid())
  name     String
  role     String  @default("")
  imageUrl String  @default("") @map("image_url")
  quote    String  @default("")
  order    Int     @default(0)
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("team_members")
}

model AppointmentAssignedUser {
  id String @id @default(cuid())

  appointmentId String @map("appointment_id")
  userId        String @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, userId])
  @@map("appointment_assigned_users")
}



model TaskAttachment {
  id         String    @id @default(cuid())
  taskId     String    @map("task_id")
  userId     String    @map("user_id")
  fileName   String    @map("file_name")
  fileUrl    String    @map("file_url")
  fileType   String    @map("file_type")
  fileSize   Int       @map("file_size")
  isInternal     Boolean   @default(false) @map("is_internal")
  status         String    @default("active")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  reviewStatus   String?   @map("review_status")   // pending | approved | changes_requested
  reviewComment  String?   @map("review_comment")
  reviewedAt     DateTime? @map("reviewed_at")
  reviewedById   String?   @map("reviewed_by_id")
  task       Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("task_attachments")
}

model TaskTemplate {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String
  description String   @default("")
  category    String   @default("general") // reel | campaign | branding | design | content | general
  visibility  String   @default("internal")
  priority    String   @default("medium")
  subtasks    Json     @default("[]") // [{title, description, visibility}]
  estimatedDays Int    @default(0) @map("estimated_days")
  isActive    Boolean  @default(true) @map("is_active")
  workspaceId String   @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@map("task_templates")
}

model TaskFeedback {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  type      String   // approved | rejected | changes_requested
  message   String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("task_feedback")
}

// ── Proyectos / Campañas ───────────────────────────────────────────
model Project {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  clientId    String?   @map("client_id")
  name        String
  description String    @default("")
  status      String    @default("active")
  color       String    @default("#8B5CF6")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  budget      Float?
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workspace     Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client        Client?                @relation("ClientProjects", fields: [clientId], references: [id], onDelete: SetNull)
  creator       User                   @relation("ProjectCreator", fields: [createdBy], references: [id])
  assignedUsers ProjectAssignedUser[]
  milestones    Milestone[]            @relation("ProjectMilestones")
  tasks         Task[]                 @relation("ProjectTasks")

  @@index([workspaceId, status])
  @@map("projects")
}

model ProjectAssignedUser {
  id        String  @id @default(cuid())
  projectId String  @map("project_id")
  userId    String  @map("user_id")
  role      String  @default("member")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("ProjectUsers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_assigned_users")
}

model Milestone {
  id               String   @id @default(cuid())
  clientId         String   @map("client_id")
  title            String
  description      String   @default("")
  date             DateTime
  status           String   @default("upcoming") // upcoming | in_progress | review | completed | delayed
  type             String   @default("other") // inicio_proyecto | grabacion | entrega_diseno | revision_cliente | lanzamiento_campana | publicacion_contenido | entrega_final | reporte_mensual | other
  progress         Int      @default(0) // 0-100
  responsibleId    String?  @map("responsible_id")
  visibleToClient  Boolean  @default(true) @map("visible_to_client")
  comments         String   @default("")
  workspaceId      String   @map("workspace_id")
  projectId        String?  @map("project_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  responsible User?  @relation("MilestoneResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  tasks       Task[] @relation("MilestoneTasks")
  project     Project?  @relation("ProjectMilestones", fields: [projectId], references: [id], onDelete: SetNull)
  @@index([clientId, workspaceId])
  @@map("milestones")
}

model DeliverableLog {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  status    String
  note      String   @default("")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  @@map("deliverable_logs")
}

model AnalyticsSnapshot {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  period      String   // "2025-01" (mensual) | "2025-W03" (semanal)
  type        String   // "monthly_tasks" | "weekly_meetings"
  data        Json     // { completed, byUser, byClient, avgDays, total }
  createdAt   DateTime @default(now()) @map("created_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, period, type])
  @@map("analytics_snapshots")
}

model ChatUnread {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  workspaceId String   @map("workspace_id")
  room        String   // "TEAM" | "SUPPORT" | "PROJECT" | "PRIVATE" | clientId
  count       Int      @default(0)
  lastReadAt  DateTime @default(now()) @map("last_read_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId, room])
  @@index([userId, workspaceId])
  @@map("chat_unreads")
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  email       String
  role        Role      @default(TEAM_MEMBER)
  token       String    @unique
  invitedBy   String    @map("invited_by")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  isClient    Boolean   @default(false) @map("is_client")
  clientName  String?   @map("client_name")
  createdAt   DateTime  @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inviter   User      @relation("InvitedBy", fields: [invitedBy], references: [id])

  @@index([token])
  @@index([workspaceId])
  @@map("workspace_invites")
}
model Channel {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  name        String
  icon        String   @default("hash")
  subtitle    String?
  isPrivate   Boolean  @default(false) @map("is_private")  // canal privado de grupo
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User             @relation("ChannelCreator", fields: [createdBy], references: [id])
  members   ChannelMember[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("channels")
}

model ChannelMember {
  id        String @id @default(cuid())
  channelId String @map("channel_id")
  userId    String @map("user_id")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@map("channel_members")
}


model AiSession {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  workspaceId String   @map("workspace_id")
  title       String   @default("Nueva conversación")
  messages    Json     @default("[]")
  model       String   @default("turbo")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  // Sesión de chat en tiempo real
  room        String?  // room del chat donde está activa
  mode        String   @default("standalone") // standalone | individual | group
  active      Boolean  @default(true)
  activatedBy String?  @map("activated_by") // userId que activó la sesión
  lastActivity DateTime? @map("last_activity")
  expiresAt   DateTime? @map("expires_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, workspaceId])
  @@index([room, workspaceId, active])
  @@map("ai_sessions")
}

// Web Push subscriptions para PWA notifications
model PushSubscription {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  workspaceId  String   @map("workspace_id")
  endpoint     String   @unique
  p256dh       String   // Public key
  auth         String   // Auth secret
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, workspaceId])
  @@map("push_subscriptions")
}
